# Hatchet (full self-hosted stack) + worker — production config.
# Copy to `.env` (gitignored) and fill in. `docker compose` reads it automatically.

# ── Pinned image tags (never :latest) ──────────────────────────────────────
HATCHET_VERSION=v0.89.6      # all Hatchet components (migrate/admin/engine/dashboard) ship at one version
HATCHET_PG_TAG=15.6
EXTRACTION_API_TAG=latest    # or a git SHA / release tag for the worker image

# ── Hatchet state database (isolated from the app `crypto` DB) ──────────────
HATCHET_PG_USER=hatchet
HATCHET_PG_PASSWORD=          # generate a strong password
HATCHET_PG_DB=hatchet

# ── hatchet-lite/engine server config (baked into the config volume by setup-config) ──
HATCHET_SERVER_URL=          # public dashboard URL, e.g. https://hatchet.internal.example.com
HATCHET_COOKIE_DOMAIN=       # e.g. hatchet.internal.example.com
HATCHET_COOKIE_INSECURE=f    # "f" behind TLS; "t" only for plain-HTTP local
HATCHET_COOKIE_SECRETS=      # two space-separated random strings: "$(openssl rand -hex 16) $(openssl rand -hex 16)"
HATCHET_ADMIN_EMAIL=         # seeded dashboard admin (replaces admin@example.com)
HATCHET_ADMIN_PASSWORD=      # strong password
HATCHET_ADMIN_NAME=Admin
HATCHET_DASHBOARD_PORT=8080
HATCHET_GRPC_PORT=7077
# What clients (worker + the extraction-api facade) dial to reach the engine.
#   same-host compose: hatchet-engine:7070   (docker network DNS, engine's container port)
#   Railway:           <hatchet-engine>.railway.internal:7070
HATCHET_GRPC_BROADCAST=hatchet-engine:7070

# ── Worker (set HATCHET_CLIENT_TOKEN after running ./gen-token.sh) ──────────
HATCHET_CLIENT_TOKEN=        # tenant token from ./gen-token.sh (also set on the extraction-api service)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_GLOBAL_RATE_PER_MIN=100    # set BELOW the real provider quota
CLAUDE_GLOBAL_RATE_PER_MIN=100
HATCHET_WORKER_SLOTS=10
LLM_MAX_CALLS_PER_HOUR=0          # spend circuit-breaker ceiling; 0 = disabled
