# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/podcast_db

# =============================================================================
# Embeddings (optional — premium pipeline only, when enabled)
# =============================================================================
# Enable embedding generation and storage
# Set to false to disable embeddings (useful for deployment without Ollama)
ENABLE_EMBEDDINGS=false
OLLAMA_EMBEDDING_URL=http://localhost:11435
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Embedding service LRU cache
CACHE_MAX_SIZE=10000
CACHE_TTL_HOURS=1

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# LLM provider API keys
# =============================================================================
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Anthropic API key — required for the news-claim Claude fallback endpoint
ANTHROPIC_API_KEY=

# =============================================================================
# Gemini Guest/Host/Keyword Extraction
# =============================================================================
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_EXTRACTION_TEMPERATURE=0.0

# =============================================================================
# Premium Claim Extraction (POST /extract/claims/premium)
# =============================================================================
# Model for premium claim extraction with full-transcript context
GEMINI_PREMIUM_MODEL=gemini-2.5-pro
GEMINI_PREMIUM_TEMPERATURE=0.2

# =============================================================================
# News Claim Extraction (POST /extract/news/claims) — scoped to news only
# =============================================================================
# Separate from GEMINI_PREMIUM_MODEL on purpose so the podcast premium pipeline
# is unaffected. gemini-3.5-flash + low thinking is ~2-5x faster than
# gemini-2.5-pro at equal/better claim quality (benchmarked 2026-05-27).
# Called directly via google-genai (thinking_level needs the consolidated SDK).
GEMINI_NEWS_CLAIM_MODEL=gemini-3.5-flash
GEMINI_NEWS_CLAIM_TEMPERATURE=0.2
# minimal | low | medium | high. 'low' is adaptive (fast on light stories,
# thinks on dense ones) and holds coverage; 'minimal' degrades dense stories.
GEMINI_NEWS_CLAIM_THINKING_LEVEL=low

# --- Claude fallback (POST /extract/news/claims/claude) ---
# Runs the EXACT SAME strong prompt as the Gemini endpoint, just on Claude.
# news-worker calls this only when the Gemini path errors out, so a Gemini
# failure no longer drops the pipeline onto a weaker prompt. REQUIRES
# ANTHROPIC_API_KEY (set above) — set it in prod/Railway.
NEWS_CLAIM_CLAUDE_MODEL=claude-sonnet-4-5
NEWS_CLAIM_CLAUDE_MAX_TOKENS=32000

# =============================================================================
# API Configuration
# =============================================================================
# API timeout in seconds (0 = no timeout, recommended for long-running batch operations)
API_TIMEOUT=0
API_HOST=0.0.0.0

# API port (Railway sets this via PORT environment variable automatically)
PORT=8000

# API authentication key
API_KEY=

# =============================================================================
# Hatchet (task orchestration) — used by the worker and the API enqueue facade
# =============================================================================
# Tenant API token from the Hatchet dashboard (starts with "ey...").
HATCHET_CLIENT_TOKEN=
# Private gRPC host:port of the hatchet-lite engine (Railway private networking).
HATCHET_CLIENT_HOST_PORT=hatchet-lite.railway.internal:7077
# Self-hosted over private networking uses no TLS. Any value other than
# "tls"/"mtls" selects an insecure channel.
HATCHET_CLIENT_TLS_STRATEGY=none
# Max concurrent task runs per worker (provider rate limit is the real throttle).
HATCHET_WORKER_SLOTS=10
# Global provider rate limits (calls/min) enforced by Hatchet across all workers.
# Set below the true provider quota (Hatchet uses fixed windows).
GEMINI_GLOBAL_RATE_PER_MIN=100
CLAUDE_GLOBAL_RATE_PER_MIN=100
# Spend circuit breaker: per-provider hourly LLM call ceiling (0 = disabled).
LLM_MAX_CALLS_PER_HOUR=0
